{
	"info": {
		"_postman_id": "nexledger-robustness-test-collection",
		"name": "NexLedger Robustness Tests",
		"description": "Comprehensive test scenarios including security, RBAC, and validation edge cases.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "01. Auth & Security",
			"item": [
				{
					"name": "Success Login (Admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
									"if (jsonData.success) {",
									"    pm.environment.set(\"admin_accessToken\", jsonData.data.accessToken);",
									"    pm.environment.set(\"admin_refreshToken\", jsonData.data.refreshToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@nexledger.com\",\n    \"password\": \"password123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/auth/login" }
					}
				},
				{
					"name": "Negative: Login Wrong Password",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Expect 401 Unauthorized\", function () { pm.response.to.have.status(401); });",
									"pm.test(\"Error code is correct\", function () { pm.expect(pm.response.json().error.code).to.eql(\"UNAUTHORIZED\"); });"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@nexledger.com\",\n    \"password\": \"wrongpassword\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/auth/login" }
					}
				},
				{
					"name": "Negative: Access Without Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Expect 401 Unauthorized\", function () { pm.response.to.have.status(401); });"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/records" }
					}
				}
			]
		},
		{
			"name": "02. RBAC Permissions",
			"item": [
				{
					"name": "Login as Viewer",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.success) { pm.environment.set(\"viewer_accessToken\", jsonData.data.accessToken); }"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"viewer@nexledger.com\",\n    \"password\": \"password123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/auth/login" }
					}
				},
				{
					"name": "Negative: Viewer Try Create (RBAC)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Expect 403 Forbidden\", function () { pm.response.to.have.status(403); });"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{viewer_accessToken}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"amount\": 100,\n    \"type\": \"expense\",\n    \"category\": \"dining\",\n    \"date\": \"2024-01-01\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/records" }
					}
				},
				{
					"name": "Negative: Viewer Try Analytics (RBAC)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Expect 403 Forbidden\", function () { pm.response.to.have.status(403); });"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{viewer_accessToken}}" }
						],
						"url": { "raw": "{{baseUrl}}/analytics/summary" }
					}
				}
			]
		},
		{
			"name": "03. Validation Edge Cases",
			"item": [
				{
					"name": "Negative: Invalid Amount (Negative)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Expect 400 Bad Request\", function () { pm.response.to.have.status(400); });",
									"pm.test(\"Details contain error\", function () { pm.expect(pm.response.json().error.details[0].message).to.include(\"greater than 0\"); });"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{admin_accessToken}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"amount\": -50,\n    \"type\": \"expense\",\n    \"category\": \"dining\",\n    \"date\": \"2024-01-01\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/records" }
					}
				},
				{
					"name": "Negative: Invalid Date (Future)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Expect 400 Bad Request\", function () { pm.response.to.have.status(400); });"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{admin_accessToken}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"amount\": 100,\n    \"type\": \"expense\",\n    \"category\": \"dining\",\n    \"date\": \"2099-01-01\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/records" }
					}
				}
			]
		},
		{
			"name": "04. Data Retrieval",
			"item": [
				{
					"name": "Filter by Date Range",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
									"pm.test(\"Data is array\", function () { pm.expect(pm.response.json().data.items).to.be.an(\"array\"); });"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{admin_accessToken}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/records?startDate=2023-01-01&endDate=2024-12-31",
							"host": [ "{{baseUrl}}" ],
							"path": [ "records" ],
							"query": [
								{ "key": "startDate", "value": "2023-01-01" },
								{ "key": "endDate", "value": "2024-12-31" }
							]
						}
					}
				}
			]
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:5000/api", "type": "string" },
		{ "key": "admin_accessToken", "value": "", "type": "string" },
		{ "key": "viewer_accessToken", "value": "", "type": "string" }
	]
}
